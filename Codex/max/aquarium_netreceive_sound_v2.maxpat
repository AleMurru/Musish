    "boxes": [
      { "box": { "id": "c1", "maxclass": "comment", "text": "Acquario Boids — netreceive v2, NO oscparse. Python sends plain Max messages on UDP 7401.", "patching_rect": [30.0, 20.0, 700.0, 20.0] } },
      { "box": { "id": "lb", "maxclass": "newobj", "text": "loadbang", "patching_rect": [30.0, 55.0, 70.0, 22.0] } },
      { "box": { "id": "mf", "maxclass": "message", "text": "220.", "patching_rect": [115.0, 55.0, 50.0, 22.0] } },
      { "box": { "id": "ma", "maxclass": "message", "text": "0.10", "patching_rect": [180.0, 55.0, 50.0, 22.0] } },
      { "box": { "id": "nr", "maxclass": "newobj", "text": "netreceive -u 7401", "patching_rect": [30.0, 100.0, 130.0, 22.0] } },
      { "box": { "id": "pr", "maxclass": "print", "text": "PLAIN_RAW_7401", "patching_rect": [180.0, 100.0, 130.0, 22.0] } },
      { "box": { "id": "rt", "maxclass": "newobj", "text": "route direct midi note rest descriptors controls section event", "patching_rect": [30.0, 145.0, 395.0, 22.0] } },
      { "box": { "id": "ud", "maxclass": "newobj", "text": "unpack f f f f f f f", "patching_rect": [30.0, 195.0, 175.0, 22.0] } },
      { "box": { "id": "c2", "maxclass": "comment", "text": "direct = mean_speed energy center_x center_y density spread density_fader", "patching_rect": [215.0, 195.0, 480.0, 20.0] } },
      { "box": { "id": "fs", "maxclass": "flonum", "patching_rect": [30.0, 240.0, 70.0, 22.0] } },
      { "box": { "id": "c3", "maxclass": "comment", "text": "mean_speed", "patching_rect": [105.0, 242.0, 90.0, 20.0] } },
      { "box": { "id": "ef", "maxclass": "newobj", "text": "expr 80. + ($f1 * 820.)", "patching_rect": [30.0, 275.0, 165.0, 22.0] } },
      { "box": { "id": "pf", "maxclass": "newobj", "text": "pack f 50", "patching_rect": [30.0, 310.0, 75.0, 22.0] } },
      { "box": { "id": "lf", "maxclass": "newobj", "text": "line~", "patching_rect": [30.0, 345.0, 55.0, 22.0] } },
      { "box": { "id": "cy", "maxclass": "newobj", "text": "cycle~", "patching_rect": [30.0, 380.0, 60.0, 22.0] } },
      { "box": { "id": "fe", "maxclass": "flonum", "patching_rect": [285.0, 240.0, 70.0, 22.0] } },
      { "box": { "id": "c4", "maxclass": "comment", "text": "energy", "patching_rect": [360.0, 242.0, 70.0, 20.0] } },
      { "box": { "id": "ea", "maxclass": "newobj", "text": "expr 0.03 + ($f1 * 0.27)", "patching_rect": [285.0, 275.0, 175.0, 22.0] } },
      { "box": { "id": "pa", "maxclass": "newobj", "text": "pack f 50", "patching_rect": [285.0, 310.0, 75.0, 22.0] } },
      { "box": { "id": "la", "maxclass": "newobj", "text": "line~", "patching_rect": [285.0, 345.0, 55.0, 22.0] } },
      { "box": { "id": "mul", "maxclass": "newobj", "text": "*~", "patching_rect": [30.0, 430.0, 40.0, 22.0] } },
