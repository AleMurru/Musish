      { "box": { "id": "c5", "maxclass": "comment", "text": "Lock patch Ctrl+E, click ezdac~. You should hear a default tone immediately; boids then modulate it.", "patching_rect": [90.0, 502.0, 650.0, 20.0] } },
      { "box": { "id": "um", "maxclass": "newobj", "text": "unpack i i i i i i", "patching_rect": [650.0, 195.0, 150.0, 22.0] } },
      { "box": { "id": "c6", "maxclass": "comment", "text": "midi = event_id midi_note velocity duration_ms layer_id section_id", "patching_rect": [810.0, 195.0, 260.0, 35.0] } },
